<%- include('./includes/register/header.ejs') -%>

<div class="auth-glow"></div>
<div class="auth-glow-2"></div>

<div class="auth-card" style="position:relative;z-index:1;">
  <div class="auth-logo">MCI</div>
  <div class="auth-tagline">Telecom CRM Platform</div>

  <div class="auth-title">Create Account</div>
  <div class="auth-sub">Join the MCI CRM platform today</div>

  <form action="/check/register" method="post" class="auth-form">
    <div class="form-group">
      <label>Full Name</label>
      <input type="text" name="name" placeholder="Your name" required />
    </div>
    <div class="form-group">
      <label>Phone Number</label>
      <input type="number" name="phone" placeholder="09xxxxxxxxx" required />
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" placeholder="••••••••" required />
    </div>
    <div class="form-group">
      <label>Confirm Password</label>
      <input type="password" name="confirmPassword" placeholder="••••••••" required />
    </div>
    <button type="submit" class="auth-submit">Create Account →</button>
  </form>

  <div class="auth-footer">
    Already have an account? <a href="/login">Sign in</a>
  </div>
</div>

<%- include('./includes/register/footer.ejs') -%>
