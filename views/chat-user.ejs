<%- include('./includes/chat/header.ejs') -%>
<div class="chat-container">
  <div class="chat-header">
    <h2>💬 صحبت با پشتیبان</h2>
    <div class="user-info">
      <p>سلام <strong><%= user.name %></strong></p>
      <form action="/logout" style="display:inline;">
        <button type="submit" class="EXIT">EXIT</button>
      </form>
    </div>
  </div>

  <div class="messages" id="messages">
    <% messages.forEach(msg => { %>
      <div class="message <%= msg.userId === user.id ? 'mine' : 'other' %>">
        <span class="name"><%= msg.userName %></span>
        <p class="text"><%= msg.text %></p>
        <span class="time"><%= new Date(msg.createdAt).toLocaleDateString('fa-IR') %></span>
      </div>
    <% }) %>
  </div>

  <form id="chat-form" class="chat-form">
    <input type="text" id="message-input" placeholder="پیام خود را بنویسید..." autocomplete="off">
    <button type="submit">ارسال</button>
  </form>
</div>

<script>
  document.getElementById('chat-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = document.getElementById('message-input').value;

    if (!text.trim()) return;

    const response = await fetch('/chat/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text })
    });

    if (response.ok) {
      document.getElementById('message-input').value = '';
      
      // نمایش پیام فوری
      const messagesDiv = document.getElementById('messages');
      const messageEl = document.createElement('div');
      messageEl.className = 'message mine';
      messageEl.innerHTML = `
        <span class="name"><%= user.name %></span>
        <p class="text">${text}</p>
        <span class="time">${new Date().toLocaleDateString('fa-IR')}</span>
      `;
      messagesDiv.appendChild(messageEl);
      messagesDiv.scrollTop = messagesDiv.scrollHeight;
    }
  });

  // اسکرول خودکار به پایین
  const messagesDiv = document.getElementById('messages');
  messagesDiv.scrollTop = messagesDiv.scrollHeight;
</script>

<%- include('./includes/chat/footer.ejs') -%>
