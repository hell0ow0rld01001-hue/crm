<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MCI — Choose Your Plan</title>
  <link rel="stylesheet" href="/css/shared.css">
  <style>
    /* ---- Layout ---- */
    header {
      padding:18px 40px;
      display:flex; justify-content:space-between; align-items:center;
      border-bottom:1px solid var(--border);
      position:sticky; top:0; z-index:100;
      background:rgba(9,9,26,.9); backdrop-filter:blur(12px);
    }
    .logo { font-size:1.7rem; font-weight:800; background:var(--accent-gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .nav-links a { color:var(--text-muted); text-decoration:none; margin-left:24px; font-size:.9rem; font-weight:600; transition:color .2s; }
    .nav-links a:hover { color:var(--text-primary); }

    /* ---- Hero ---- */
    .hero { text-align:center; padding:64px 20px 48px; }
    .hero h1 { font-size:2.8rem; font-weight:800; color:var(--text-primary); margin-bottom:12px; }
    .hero h1 span { background:var(--accent-gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .hero p { color:var(--text-muted); font-size:1rem; }
    .duration-pill {
      display:inline-flex; align-items:center; gap:8px;
      margin-top:16px; padding:8px 20px;
      border-radius:30px; font-size:.85rem;
      background:var(--green-dim); border:1px solid rgba(74,222,128,.35);
      color:var(--green); font-weight:600;
    }

    /* ---- Active plan strip ---- */
    .active-strip {
      max-width:700px; margin:0 auto 40px;
      background:var(--bg-secondary);
      border:1px solid var(--border-accent);
      border-radius:14px; padding:16px 24px;
      display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;
    }
    .strip-left .label { font-size:.75rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:.06em; }
    .strip-left .value { font-size:1.1rem; font-weight:700; color:var(--accent-light); margin-top:2px; }
    .progress-mini { width:160px; }
    .progress-mini .bar-bg { height:6px; background:var(--border); border-radius:10px; overflow:hidden; }
    .progress-mini .bar-fill { height:100%; background:var(--accent-gradient); border-radius:10px; }
    .progress-mini .bar-label { font-size:.75rem; color:var(--text-muted); margin-top:4px; text-align:right; }

    /* ---- Plans grid ---- */
    .plans-grid { display:flex; justify-content:center; gap:24px; padding:0 40px 80px; flex-wrap:wrap; }

    .plan-card {
      background:var(--bg-secondary);
      border:1px solid var(--border);
      border-radius:22px; padding:38px 30px;
      width:300px; position:relative;
      transition:transform .3s, border-color .3s, box-shadow .3s;
    }
    .plan-card:hover { transform:translateY(-6px); border-color:var(--border-accent); box-shadow:0 0 40px rgba(124,58,237,.1); }
    .plan-card.popular {
      border-color:rgba(124,58,237,.6);
      background:linear-gradient(145deg,var(--bg-secondary),rgba(124,58,237,.06));
    }
    .popular-badge {
      position:absolute; top:-14px; left:50%; transform:translateX(-50%);
      background:var(--accent-gradient); color:#fff;
      padding:4px 20px; border-radius:20px; font-size:.78rem; font-weight:600;
      white-space:nowrap; box-shadow:0 4px 20px rgba(124,58,237,.4);
    }

    .plan-name { font-size:1.1rem; font-weight:700; color:var(--accent-light); margin-bottom:6px; }
    .plan-price { font-size:3rem; font-weight:800; color:var(--text-primary); margin:10px 0; }
    .plan-price sup { font-size:1.2rem; vertical-align:top; margin-top:12px; color:var(--text-muted); }
    .plan-price span { font-size:1rem; color:var(--text-dim); font-weight:400; }

    /* duration badge */
    .plan-duration {
      display:inline-flex; align-items:center; gap:6px;
      background:var(--green-dim); border:1px solid rgba(74,222,128,.3);
      color:var(--green); border-radius:8px;
      padding:4px 12px; font-size:.8rem; font-weight:600; margin-bottom:16px;
    }

    .plan-features { list-style:none; margin-bottom:28px; }
    .plan-features li {
      padding:9px 0; border-bottom:1px solid var(--border);
      font-size:.88rem; color:var(--text-muted);
      display:flex; align-items:center; gap:10px;
    }
    .plan-features li:last-child { border-bottom:none; }
    .plan-features li::before { content:'✓'; color:var(--accent-light); font-weight:700; }

    .plan-btn { width:100%; padding:13px; border:none; border-radius:12px; font-size:.95rem; font-weight:700; cursor:pointer; transition:all .25s; }
    .plan-btn-default { background:var(--accent-dim); color:var(--accent-light); border:1px solid var(--border-accent); }
    .plan-btn-default:hover { background:rgba(124,58,237,.3); }
    .plan-btn-popular { background:var(--accent-gradient); color:#fff; }
    .plan-btn-popular:hover { opacity:.88; transform:scale(1.02); }
    .plan-btn-active { background:var(--green-dim); color:var(--green); border:1px solid rgba(74,222,128,.35); cursor:not-allowed; }

    .back-link { text-align:center; margin-bottom:50px; }
    .back-link a { color:var(--accent-light); font-size:.9rem; }
    .back-link a:hover { text-decoration:underline; }
  </style>
</head>
<body>

  <header>
    <div class="logo">MCI</div>
    <div class="nav-links">
      <a href="/dashboard">Dashboard</a>
      <a href="/chat">Support</a>
      <% if (['doller1','doller5','doller10'].includes(currentRole)) { %>
        <a href="/crm" style="color:var(--accent-light);">CRM</a>
      <% } %>
      <a href="/logout">Logout</a>
    </div>
  </header>

  <div class="hero">
    <h1>Choose Your <span>Plan</span></h1>
    <p>Full CRM access with transparent pricing — no hidden fees</p>
    <div class="duration-pill">
      📅 All plans include <%= planDurationDays %> days of access
    </div>
  </div>

  <!-- Active plan strip -->
  <% if (currentRole && !['user','support'].includes(currentRole) && planExpiresAt) { %>
  <div class="active-strip" style="margin-left:auto;margin-right:auto;max-width:680px;">
    <div class="strip-left">
      <div class="label">Current Plan</div>
      <div class="value"><%= currentRole %></div>
    </div>
    <div class="progress-mini">
      <div class="bar-bg">
        <div class="bar-fill" style="width:<%= Math.round((remainingDays/planDurationDays)*100) %>%;"></div>
      </div>
      <div class="bar-label"><%= remainingDays %> / <%= planDurationDays %> days left</div>
    </div>
    <div style="font-size:.82rem;color:var(--text-muted);">
      Expires: <strong style="color:var(--text-primary);"><%= new Date(planExpiresAt).toLocaleDateString('en-GB') %></strong>
    </div>
  </div>
  <% } %>

  <div class="plans-grid">
    <% const planArr = [['1',plans['1']],['5',plans['5']],['10',plans['10']]]; %>
    <% planArr.forEach(([key, plan], i) => { %>
      <div class="plan-card <%= i === 1 ? 'popular' : '' %>">
        <% if (i === 1) { %><div class="popular-badge">⭐ Most Popular</div><% } %>

        <div class="plan-name"><%= plan.name %></div>
        <div class="plan-price"><sup>$</sup><%= plan.price %><span>/month</span></div>
        <div class="plan-duration">📅 <%= plan.durationDays %> days access</div>

        <ul class="plan-features">
          <% plan.features.forEach(f => { %>
            <li><%= f %></li>
          <% }) %>
        </ul>

        <% if (currentRole === plan.role) { %>
          <button class="plan-btn plan-btn-active" disabled>✓ Current Plan</button>
        <% } else { %>
          <form action="/purchase-plan" method="POST">
            <input type="hidden" name="plan" value="<%= key %>">
            <button type="submit" class="plan-btn <%= i === 1 ? 'plan-btn-popular' : 'plan-btn-default' %>">
              Get <%= plan.name %>
            </button>
          </form>
        <% } %>
      </div>
    <% }) %>
  </div>

  <div class="back-link">
    <a href="/dashboard">← Back to Dashboard</a>
  </div>

</body>
</html>
