<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>پنل پشتیبانی — MCI</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;}
    :root{
      --bg:#0a0a1a; --bg-card:#111127; --bg-hover:#181838;
      --border:rgba(255,255,255,0.06); --border-glow:rgba(124,58,237,0.4);
      --primary:#7c3aed; --primary2:#4f46e5;
      --text:#e0e0f0; --muted:#888; --dim:#555;
      --accent:#a78bfa; --light:#c4b5fd;
      --green:#4ade80; --yellow:#fbbf24; --red:#f87171; --blue:#60a5fa;
      --grad:linear-gradient(135deg,#7c3aed,#4f46e5);
    }
    body{font-family:'Segoe UI',Tahoma,sans-serif;background:var(--bg);color:var(--text);height:100vh;display:flex;overflow:hidden;}
    ::-webkit-scrollbar{width:4px;} ::-webkit-scrollbar-thumb{background:rgba(124,58,237,0.3);border-radius:10px;}

    /* ── SIDEBAR ── */
    .sidebar{width:72px;background:var(--bg-card);border-left:1px solid var(--border);display:flex;flex-direction:column;align-items:center;padding:20px 0;gap:8px;flex-shrink:0;transition:width .3s;}
    .sidebar.expanded{width:220px;align-items:flex-start;padding:20px 14px;}
    .logo-icon{width:44px;height:44px;border-radius:14px;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:1.2rem;font-weight:900;color:#fff;flex-shrink:0;margin-bottom:8px;}
    .sidebar.expanded .logo-icon{margin-right:auto;margin-left:0;}
    .logo-text{font-size:1.1rem;font-weight:800;background:var(--grad);-webkit-background-clip:text;-webkit-text-fill-color:transparent;display:none;white-space:nowrap;}
    .sidebar.expanded .logo-text{display:block;}
    .nav-btn{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:all .2s;font-size:1.2rem;border:none;background:none;flex-shrink:0;}
    .sidebar.expanded .nav-btn{width:100%;justify-content:flex-start;padding:0 12px;gap:12px;}
    .nav-btn:hover,.nav-btn.active{background:rgba(124,58,237,0.15);color:var(--light);}
    .nav-btn .nav-label{font-size:0.88rem;display:none;font-weight:500;}
    .sidebar.expanded .nav-btn .nav-label{display:block;}
    .sidebar-bottom{margin-top:auto;display:flex;flex-direction:column;align-items:center;gap:8px;width:100%;}
    .sidebar.expanded .sidebar-bottom{align-items:flex-start;}
    .agent-chip{background:rgba(124,58,237,0.1);border:1px solid var(--border-glow);border-radius:12px;padding:8px 10px;display:flex;align-items:center;gap:10px;width:44px;overflow:hidden;transition:width .3s;}
    .sidebar.expanded .agent-chip{width:100%;}
    .agent-avatar{width:28px;height:28px;border-radius:8px;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:0.85rem;font-weight:700;color:#fff;flex-shrink:0;}
    .agent-info{display:none;overflow:hidden;}
    .sidebar.expanded .agent-info{display:block;}
    .agent-name{font-size:0.82rem;font-weight:600;color:var(--light);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .agent-role{font-size:0.72rem;color:var(--dim);}

    /* ── CONV LIST ── */
    .conv-panel{width:300px;background:var(--bg-card);border-left:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0;}
    .conv-panel-header{padding:18px 16px 10px;border-bottom:1px solid var(--border);}
    .conv-panel-title{font-size:0.95rem;font-weight:700;color:var(--light);margin-bottom:4px;}
    .conv-panel-sub{font-size:0.75rem;color:var(--dim);}
    .search-input{width:100%;margin:10px 0 6px;padding:9px 14px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:0.85rem;outline:none;font-family:inherit;transition:border-color .2s;}
    .search-input:focus{border-color:var(--border-glow);}
    .search-input::placeholder{color:var(--dim);}

    /* tag filter */
    .tag-filters{display:flex;gap:5px;padding:0 0 8px;flex-wrap:wrap;}
    .tag-btn{padding:3px 10px;border-radius:20px;font-size:0.7rem;font-weight:600;border:1px solid var(--border);background:none;color:var(--dim);cursor:pointer;transition:all .15s;}
    .tag-btn:hover,.tag-btn.active{border-color:var(--primary);color:var(--accent);background:rgba(124,58,237,0.1);}
    .tag-btn.urgent{border-color:#ef4444;color:#f87171;}
    .tag-btn.urgent.active{background:rgba(239,68,68,0.1);}

    .conv-list{flex:1;overflow-y:auto;}
    .conv-item{padding:13px 16px;border-bottom:1px solid rgba(255,255,255,0.03);cursor:pointer;transition:background .15s;position:relative;}
    .conv-item:hover{background:rgba(124,58,237,0.08);}
    .conv-item.active{background:rgba(124,58,237,0.18);border-right:3px solid var(--primary);}
    .conv-item-row{display:flex;align-items:center;gap:10px;}
    .conv-avatar{width:38px;height:38px;border-radius:12px;background:rgba(124,58,237,0.2);border:1px solid rgba(124,58,237,0.3);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:var(--accent);flex-shrink:0;}
    .conv-info{flex:1;overflow:hidden;}
    .conv-name{font-size:0.88rem;font-weight:600;color:var(--text);margin-bottom:3px;}
    .conv-preview{font-size:0.76rem;color:var(--dim);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
    .conv-meta{text-align:left;flex-shrink:0;}
    .conv-time{font-size:0.7rem;color:var(--dim);white-space:nowrap;}
    .conv-badge{display:inline-block;min-width:18px;height:18px;background:var(--primary);color:#fff;border-radius:10px;font-size:0.68rem;font-weight:700;text-align:center;line-height:18px;padding:0 5px;margin-top:4px;}
    .conv-tag{display:inline-block;padding:2px 7px;border-radius:10px;font-size:0.62rem;font-weight:700;margin-top:3px;}
    .conv-tag.urgent{background:rgba(239,68,68,0.2);color:#f87171;}
    .conv-tag.billing{background:rgba(234,179,8,0.2);color:#fbbf24;}
    .conv-tag.technical{background:rgba(96,165,250,0.2);color:#60a5fa;}
    .conv-tag.general{background:rgba(74,222,128,0.2);color:#4ade80;}

    /* ── CHAT MAIN ── */
    .chat-main{flex:1;display:flex;flex-direction:column;min-width:0;}
    .chat-topbar{padding:14px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:rgba(17,17,39,0.6);}
    .chat-user-info{display:flex;align-items:center;gap:12px;}
    .chat-user-avatar{width:40px;height:40px;border-radius:12px;background:var(--grad);display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;color:#fff;}
    .chat-user-name{font-size:0.95rem;font-weight:600;color:var(--text);}
    .chat-user-sub{font-size:0.75rem;color:var(--dim);}
    .topbar-actions{display:flex;gap:8px;align-items:center;}
    .pulse{display:inline-flex;align-items:center;gap:6px;font-size:0.78rem;color:var(--green);background:rgba(74,222,128,0.1);border:1px solid rgba(74,222,128,0.25);padding:4px 12px;border-radius:20px;}
    .pulse-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;}
    @keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(74,222,128,0.4);}50%{box-shadow:0 0 0 5px rgba(74,222,128,0);}}
    .topbar-tag-select{background:rgba(255,255,255,0.05);border:1px solid var(--border);color:var(--muted);border-radius:8px;padding:5px 10px;font-size:0.78rem;cursor:pointer;font-family:inherit;outline:none;}
    .topbar-tag-select:focus{border-color:var(--border-glow);}
    .del-conv-btn{padding:6px 12px;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:9px;color:#f87171;font-size:0.75rem;cursor:pointer;font-family:inherit;transition:all .2s;}
    .del-conv-btn:hover{background:rgba(239,68,68,0.2);}

    /* ── MESSAGES ── */
    .messages-area{flex:1;overflow-y:auto;padding:24px;display:flex;flex-direction:column;gap:14px;}
    .empty-state{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--dim);}
    .empty-state .icon{font-size:3.5rem;margin-bottom:16px;opacity:.5;}
    .empty-state h3{font-size:1rem;margin-bottom:6px;color:var(--muted);}
    .empty-state p{font-size:0.83rem;}
    .msg-wrapper{display:flex;gap:10px;align-items:flex-end;position:relative;}
    .msg-wrapper:hover .del-msg-btn{opacity:1;}
    .msg-wrapper.support-msg{flex-direction:row-reverse;}
    .msg-ava{width:32px;height:32px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:#fff;flex-shrink:0;}
    .msg-ava.user-ava{background:rgba(124,58,237,0.3);border:1px solid rgba(124,58,237,0.4);}
    .msg-ava.support-ava{background:var(--grad);}
    .bubble{max-width:68%;padding:11px 16px;border-radius:16px;font-size:0.88rem;line-height:1.6;position:relative;}
    .user-bubble{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:16px 16px 16px 4px;color:var(--text);}
    .support-bubble{background:linear-gradient(135deg,rgba(124,58,237,0.45),rgba(79,70,229,0.4));border:1px solid rgba(124,58,237,0.35);border-radius:16px 16px 4px 16px;color:#d8caff;}
    .bubble-name{font-size:0.7rem;color:var(--dim);margin-bottom:5px;font-weight:600;}
    .bubble-time{font-size:0.68rem;color:var(--dim);text-align:left;margin-top:5px;}
    .del-msg-btn{opacity:0;transition:opacity .2s;background:rgba(239,68,68,0.15);border:1px solid rgba(239,68,68,0.3);color:#f87171;border-radius:8px;padding:4px 8px;font-size:0.72rem;cursor:pointer;align-self:center;flex-shrink:0;font-family:inherit;}
    .del-msg-btn:hover{background:rgba(239,68,68,0.3);}

    /* typing indicator */
    .typing{display:none;padding:0 24px 10px;}
    .typing-bubble{display:inline-flex;gap:4px;padding:10px 16px;background:rgba(255,255,255,0.05);border-radius:14px 14px 14px 4px;border:1px solid var(--border);}
    .typing-dot{width:7px;height:7px;border-radius:50%;background:var(--dim);animation:blink 1.2s infinite;}
    .typing-dot:nth-child(2){animation-delay:.2s;}
    .typing-dot:nth-child(3){animation-delay:.4s;}
    @keyframes blink{0%,80%,100%{opacity:.2;}40%{opacity:1;}}

    /* ── INPUT ── */
    .chat-input-bar{padding:14px 20px;border-top:1px solid var(--border);background:rgba(124,58,237,0.03);}
    .input-row{display:flex;gap:10px;align-items:flex-end;}
    .msg-input{flex:1;padding:12px 18px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:14px;color:var(--text);font-family:inherit;font-size:0.9rem;outline:none;resize:none;max-height:120px;transition:border-color .2s;line-height:1.5;}
    .msg-input:focus{border-color:var(--border-glow);background:rgba(124,58,237,0.07);}
    .msg-input::placeholder{color:var(--dim);}
    .send-btn{width:48px;height:48px;border-radius:14px;background:var(--grad);border:none;color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:opacity .2s,transform .15s;}
    .send-btn:hover{opacity:.88;transform:scale(1.05);}
    .send-btn:disabled{opacity:.4;cursor:not-allowed;transform:none;}
    .input-hint{font-size:0.72rem;color:var(--dim);margin-top:6px;text-align:right;}

    /* Templates */
    .templates-row{display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap;}
    .tpl-btn{padding:4px 12px;background:rgba(124,58,237,0.1);border:1px solid rgba(124,58,237,0.25);border-radius:20px;color:var(--accent);font-size:0.75rem;cursor:pointer;font-family:inherit;transition:all .15s;white-space:nowrap;}
    .tpl-btn:hover{background:rgba(124,58,237,0.2);border-color:var(--primary);}
    .tpl-add-btn{padding:4px 12px;background:rgba(255,255,255,0.04);border:1px solid var(--border);border-radius:20px;color:var(--muted);font-size:0.75rem;cursor:pointer;font-family:inherit;transition:all .15s;}
    .tpl-add-btn:hover{border-color:var(--border-glow);color:var(--accent);}

    /* ── STATS BAR ── */
    .stats-bar{display:flex;gap:0;border-bottom:1px solid var(--border);}
    .stat-item{flex:1;padding:10px 12px;text-align:center;border-left:1px solid var(--border);}
    .stat-item:first-child{border-left:none;}
    .stat-val{font-size:1.2rem;font-weight:700;color:var(--accent);}
    .stat-val.red{color:var(--red);}
    .stat-val.green{color:var(--green);}
    .stat-lbl{font-size:0.68rem;color:var(--dim);margin-top:1px;}

    /* toast */
    .toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--bg-card);border:1px solid var(--border-glow);border-radius:12px;padding:12px 24px;color:var(--accent);font-size:0.88rem;opacity:0;transition:all .3s;z-index:99;}
    .toast.show{transform:translateX(-50%) translateY(0);opacity:1;}
    .toast.error{border-color:rgba(239,68,68,0.5);color:var(--red);}

    /* logout btn */
    .logout-btn{padding:7px 16px;background:transparent;border:1px solid rgba(239,68,68,0.3);border-radius:9px;color:#f87171;font-size:0.8rem;cursor:pointer;transition:all .2s;font-family:inherit;}
    .logout-btn:hover{background:rgba(239,68,68,0.1);}

    /* modal */
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:200;opacity:0;pointer-events:none;transition:opacity .2s;}
    .modal-overlay.open{opacity:1;pointer-events:auto;}
    .modal-box{background:var(--bg-card);border:1px solid var(--border-glow);border-radius:18px;padding:28px;width:380px;max-width:90vw;}
    .modal-title{font-size:1rem;font-weight:700;color:var(--light);margin-bottom:18px;}
    .modal-input{width:100%;padding:10px 14px;background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:10px;color:var(--text);font-size:0.88rem;font-family:inherit;outline:none;margin-bottom:12px;}
    .modal-input:focus{border-color:var(--border-glow);}
    .modal-actions{display:flex;gap:10px;margin-top:6px;}
    .btn-save{flex:1;padding:10px;background:var(--grad);border:none;border-radius:10px;color:#fff;font-weight:600;font-size:0.88rem;cursor:pointer;font-family:inherit;}
    .btn-cancel{padding:10px 18px;background:none;border:1px solid var(--border);border-radius:10px;color:var(--muted);font-size:0.88rem;cursor:pointer;font-family:inherit;}

    /* unanswered badge */
    .badge-unanswered{display:inline-block;background:rgba(239,68,68,0.2);color:var(--red);border-radius:20px;font-size:0.62rem;font-weight:700;padding:1px 7px;margin-right:6px;}
  </style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sidebar" id="sidebar">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;width:100%;">
    <div class="logo-icon">M</div>
    <span class="logo-text">MCI Support</span>
  </div>

  <button class="nav-btn active" onclick="setTab('chat',this)" title="چت‌ها">
    <span>💬</span><span class="nav-label">چت‌ها</span>
  </button>
  <button class="nav-btn" onclick="setTab('templates',this)" title="تمپلیت‌ها">
    <span>⚡</span><span class="nav-label">پاسخ سریع</span>
  </button>
  <button class="nav-btn" onclick="toggleSidebar()" title="گسترش">
    <span id="toggleIcon">◀</span><span class="nav-label">جمع کردن</span>
  </button>

  <div class="sidebar-bottom">
    <div class="agent-chip">
      <div class="agent-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
      <div class="agent-info">
        <div class="agent-name"><%= user.name %></div>
        <div class="agent-role">🛡 Support Agent</div>
      </div>
    </div>
    <a href="/logout" style="width:100%;display:flex;justify-content:center;">
      <button class="logout-btn" style="width:100%;">خروج</button>
    </a>
  </div>
</div>

<!-- CONV LIST -->
<div class="conv-panel">
  <div class="conv-panel-header">
    <div class="conv-panel-title">پیام‌های ورودی 📥</div>
    <div class="conv-panel-sub" id="convCount">در حال بارگذاری...</div>
    <input class="search-input" type="text" id="searchInput" placeholder="جستجوی کاربر..." oninput="filterConversations(this.value)"/>
    <div class="tag-filters">
      <button class="tag-btn active" onclick="filterByTag(null,this)">همه</button>
      <button class="tag-btn urgent" onclick="filterByTag('urgent',this)">🔴 فوری</button>
      <button class="tag-btn billing" onclick="filterByTag('billing',this)">💰 مالی</button>
      <button class="tag-btn technical" onclick="filterByTag('technical',this)">🔧 فنی</button>
      <button class="tag-btn general" onclick="filterByTag('general',this)">💬 عمومی</button>
    </div>
  </div>
  <div class="conv-list" id="convList">
    <% conversations.forEach((conv, i) => { %>
    <div class="conv-item" id="conv-<%= conv.conversationId %>"
         data-tag="<%= conv.tag || '' %>"
         onclick="openConversation('<%= conv.conversationId %>', '<%= conv.userName %>')">
      <div class="conv-item-row">
        <div class="conv-avatar"><%= conv.userName ? conv.userName.charAt(0).toUpperCase() : '?' %></div>
        <div class="conv-info">
          <div class="conv-name">
            <%= !conv.hasReply ? '<span class="badge-unanswered">بدون پاسخ</span>' : '' %>
            <%= conv.userName || 'ناشناس' %>
          </div>
          <div class="conv-preview"><%= conv.lastMessage ? conv.lastMessage.text.substring(0,40) : 'بدون پیام' %></div>
          <% if (conv.tag) { %>
          <span class="conv-tag <%= conv.tag %>"><%= conv.tag === 'urgent' ? '🔴 فوری' : conv.tag === 'billing' ? '💰 مالی' : conv.tag === 'technical' ? '🔧 فنی' : '💬 عمومی' %></span>
          <% } %>
        </div>
        <div class="conv-meta">
          <div class="conv-time"><%= conv.lastMessage ? new Date(conv.lastMessage.createdAt).toLocaleTimeString('fa-IR', {hour:'2-digit',minute:'2-digit'}) : '' %></div>
          <div class="conv-badge" style="<%= i < 5 ? '' : 'display:none;' %>"><%= conv.messages.length %></div>
        </div>
      </div>
    </div>
    <% }) %>
    <% if (conversations.length === 0) { %>
    <div style="text-align:center;padding:50px 20px;color:var(--dim);font-size:0.88rem;">هیچ مکالمه‌ای وجود ندارد</div>
    <% } %>
  </div>
</div>

<!-- CHAT MAIN -->
<div class="chat-main">

  <!-- stats bar -->
  <div class="stats-bar">
    <div class="stat-item"><div class="stat-val" id="statConvs"><%= conversations.length %></div><div class="stat-lbl">مکالمه</div></div>
    <div class="stat-item"><div class="stat-val" id="statMsgs"><%= totalMessages %></div><div class="stat-lbl">کل پیام</div></div>
    <div class="stat-item"><div class="stat-val green" id="statToday"><%= todayMessages %></div><div class="stat-lbl">امروز</div></div>
    <div class="stat-item"><div class="stat-val red" id="statUnanswered"><%= unansweredConvs %></div><div class="stat-lbl">بدون پاسخ</div></div>
    <div class="stat-item"><div class="stat-val"><%= totalUsers %></div><div class="stat-lbl">کاربران</div></div>
  </div>

  <!-- topbar -->
  <div class="chat-topbar" id="chatTopbar" style="display:none;">
    <div class="chat-user-info">
      <div class="chat-user-avatar" id="topbarAvatar">?</div>
      <div>
        <div class="chat-user-name" id="topbarName">—</div>
        <div class="chat-user-sub" id="topbarSub">انتخاب کنید</div>
      </div>
    </div>
    <div class="topbar-actions">
      <select class="topbar-tag-select" id="convTagSelect" onchange="setConvTag(this.value)" title="تگ مکالمه">
        <option value="">🏷 تگ</option>
        <option value="urgent">🔴 فوری</option>
        <option value="billing">💰 مالی</option>
        <option value="technical">🔧 فنی</option>
        <option value="general">💬 عمومی</option>
      </select>
      <button class="del-conv-btn" onclick="deleteConversation()" title="حذف کل مکالمه">🗑 حذف مکالمه</button>
      <div class="pulse"><span class="pulse-dot"></span> Live</div>
    </div>
  </div>

  <!-- messages -->
  <div class="messages-area" id="messagesArea">
    <div class="empty-state">
      <div class="icon">💬</div>
      <h3>مکالمه‌ای انتخاب نشده</h3>
      <p>از لیست سمت راست یک کاربر را انتخاب کنید</p>
    </div>
  </div>

  <div class="typing" id="typingIndicator">
    <div class="typing-bubble">
      <div class="typing-dot"></div>
      <div class="typing-dot"></div>
      <div class="typing-dot"></div>
    </div>
  </div>

  <!-- input -->
  <div class="chat-input-bar" id="chatInputBar" style="display:none;">
    <div class="templates-row" id="templatesRow">
      <% templates.forEach(t => { %>
      <button class="tpl-btn" onclick="useTemplate('<%= t.text.replace(/'/g, "\\'") %>')" title="<%= t.text %>">⚡ <%= t.title %></button>
      <% }) %>
      <button class="tpl-add-btn" onclick="openModal('modal-tpl')">+ افزودن</button>
    </div>
    <div class="input-row">
      <textarea class="msg-input" id="msgInput" rows="1" placeholder="پیام پشتیبانی..."></textarea>
      <button class="send-btn" id="sendBtn" onclick="sendMessage()">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
        </svg>
      </button>
    </div>
    <div class="input-hint">Enter برای ارسال • Shift+Enter برای خط جدید</div>
  </div>

</div>

<div class="toast" id="toast"></div>

<!-- Modal: تمپلیت جدید -->
<div class="modal-overlay" id="modal-tpl">
  <div class="modal-box">
    <div class="modal-title">⚡ افزودن پاسخ سریع</div>
    <input class="modal-input" id="tpl-title" placeholder="عنوان (مثلاً: خوشامد)" />
    <textarea class="modal-input" id="tpl-text" rows="3" placeholder="متن پاسخ..." style="resize:vertical;"></textarea>
    <div class="modal-actions">
      <button class="btn-save" onclick="submitTemplate()">ذخیره</button>
      <button class="btn-cancel" onclick="closeModal('modal-tpl')">انصراف</button>
    </div>
  </div>
</div>

<script>
  const ME_ID   = '<%= user.id %>';
  const ME_NAME = '<%= user.name %>';

  let currentConvId   = null;
  let currentUserName = null;
  let pollInterval    = null;
  let lastMsgCount    = 0;
  let sidebarOpen     = false;
  let activeTagFilter = null;

  /* ── sidebar toggle ── */
  function toggleSidebar() {
    sidebarOpen = !sidebarOpen;
    const sb = document.getElementById('sidebar');
    sb.classList.toggle('expanded', sidebarOpen);
    document.getElementById('toggleIcon').textContent = sidebarOpen ? '▶' : '◀';
  }

  /* ── tabs ── */
  function setTab(tab, el) {
    document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
    if (el) el.classList.add('active');
  }

  /* ── tag filter ── */
  function filterByTag(tag, btn) {
    activeTagFilter = tag;
    document.querySelectorAll('.tag-btn').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    document.querySelectorAll('.conv-item').forEach(item => {
      const t = item.dataset.tag || '';
      item.style.display = (!tag || t === tag) ? '' : 'none';
    });
  }

  /* ── set conv tag ── */
  function setConvTag(tag) {
    if (!currentConvId) return;
    const el = document.getElementById('conv-' + currentConvId);
    if (el) {
      el.dataset.tag = tag;
      let tagEl = el.querySelector('.conv-tag');
      if (tag) {
        const labels = {urgent:'🔴 فوری', billing:'💰 مالی', technical:'🔧 فنی', general:'💬 عمومی'};
        if (!tagEl) {
          tagEl = document.createElement('span');
          el.querySelector('.conv-info').appendChild(tagEl);
        }
        tagEl.className = 'conv-tag ' + tag;
        tagEl.textContent = labels[tag] || tag;
      } else if (tagEl) {
        tagEl.remove();
      }
    }
    showToast('🏷 تگ مکالمه ذخیره شد');
  }

  /* ── open a conversation ── */
  function openConversation(convId, userName) {
    currentConvId   = convId;
    currentUserName = userName;
    lastMsgCount    = 0;

    document.querySelectorAll('.conv-item').forEach(el => el.classList.remove('active'));
    const el = document.getElementById('conv-' + convId);
    if (el) {
      el.classList.add('active');
      const currentTag = el.dataset.tag || '';
      document.getElementById('convTagSelect').value = currentTag;
    }

    document.getElementById('chatTopbar').style.display = 'flex';
    document.getElementById('chatInputBar').style.display = 'block';
    document.getElementById('topbarAvatar').textContent = userName.charAt(0).toUpperCase();
    document.getElementById('topbarName').textContent = userName;
    document.getElementById('topbarSub').textContent = 'در حال بارگذاری...';

    loadMessages(true);

    if (pollInterval) clearInterval(pollInterval);
    pollInterval = setInterval(() => loadMessages(false), 3500);
  }

  /* ── load messages ── */
  async function loadMessages(forceScroll) {
    if (!currentConvId) return;
    try {
      const r = await fetch(`/support/api/conversation/${currentConvId}`);
      const data = await r.json();
      const msgs = data.messages || [];
      document.getElementById('topbarSub').textContent = `${msgs.length} پیام`;
      if (msgs.length === lastMsgCount && !forceScroll) return;
      const isNew = msgs.length > lastMsgCount && !forceScroll;
      lastMsgCount = msgs.length;
      renderMessages(msgs, forceScroll || isNew);
    } catch(e) { console.error(e); }
  }

  /* ── render messages ── */
  function renderMessages(msgs, shouldScroll) {
    const area = document.getElementById('messagesArea');
    area.innerHTML = '';
    if (msgs.length === 0) {
      area.innerHTML = '<div class="empty-state"><div class="icon">📭</div><h3>بدون پیام</h3><p>اولین پیام را بفرستید</p></div>';
      return;
    }
    msgs.forEach(msg => {
      const isSupport = msg.role === 'support';
      const wrapper = document.createElement('div');
      wrapper.className = `msg-wrapper ${isSupport ? 'support-msg' : ''}`;
      const initial = msg.userName ? msg.userName.charAt(0).toUpperCase() : '?';
      const time = new Date(msg.createdAt).toLocaleTimeString('fa-IR', {hour:'2-digit', minute:'2-digit'});
      const msgId = msg._id;
      wrapper.innerHTML = `
        <div class="msg-ava ${isSupport ? 'support-ava' : 'user-ava'}">${initial}</div>
        <div>
          <div class="bubble ${isSupport ? 'support-bubble' : 'user-bubble'}">
            <div class="bubble-name">${msg.userName}${isSupport ? ' (پشتیبانی)' : ''}</div>
            <div>${msg.text}</div>
            <div class="bubble-time">${time}</div>
          </div>
        </div>
        <button class="del-msg-btn" onclick="deleteMessage('${msgId}')" title="حذف پیام">🗑</button>`;
      area.appendChild(wrapper);
    });
    if (shouldScroll) area.scrollTop = area.scrollHeight;
  }

  /* ── delete message ── */
  async function deleteMessage(msgId) {
    if (!confirm('این پیام حذف شود؟')) return;
    try {
      const r = await fetch('/support/api/message/delete', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ messageId: msgId })
      });
      if (r.ok) {
        showToast('🗑 پیام حذف شد');
        await loadMessages(true);
        refreshConvList();
      } else showToast('❌ خطا در حذف', true);
    } catch(e) { showToast('❌ خطا در حذف', true); }
  }

  /* ── delete whole conversation ── */
  async function deleteConversation() {
    if (!currentConvId) return;
    if (!confirm(`کل مکالمه ${currentUserName} حذف شود؟`)) return;
    try {
      const r = await fetch('/support/api/conversation/delete', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ conversationId: currentConvId })
      });
      if (r.ok) {
        showToast('🗑 مکالمه حذف شد');
        const el = document.getElementById('conv-' + currentConvId);
        if (el) el.remove();
        document.getElementById('chatTopbar').style.display = 'none';
        document.getElementById('chatInputBar').style.display = 'none';
        document.getElementById('messagesArea').innerHTML = '<div class="empty-state"><div class="icon">💬</div><h3>مکالمه‌ای انتخاب نشده</h3><p>از لیست سمت راست یک کاربر را انتخاب کنید</p></div>';
        currentConvId = null;
        if (pollInterval) clearInterval(pollInterval);
        refreshConvList();
      } else showToast('❌ خطا در حذف', true);
    } catch(e) { showToast('❌ خطا در حذف', true); }
  }

  /* ── send message ── */
  async function sendMessage() {
    const input = document.getElementById('msgInput');
    const text = input.value.trim();
    if (!text || !currentConvId) return;

    const btn = document.getElementById('sendBtn');
    btn.disabled = true;
    input.value = '';
    input.style.height = 'auto';

    try {
      const r = await fetch('/support/send', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ text, conversationId: currentConvId })
      });
      if (r.ok) {
        await loadMessages(true);
        showToast('✓ ارسال شد');
        refreshConvList();
      }
    } catch(e) { showToast('❌ خطا در ارسال', true); }
    btn.disabled = false;
    input.focus();
  }

  /* ── use template ── */
  function useTemplate(text) {
    const input = document.getElementById('msgInput');
    input.value = text;
    input.focus();
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  }

  /* ── template modal ── */
  function openModal(id) { document.getElementById(id).classList.add('open'); }
  function closeModal(id) { document.getElementById(id).classList.remove('open'); }

  async function submitTemplate() {
    const title = document.getElementById('tpl-title').value.trim();
    const text = document.getElementById('tpl-text').value.trim();
    if (!title || !text) { showToast('❌ عنوان و متن الزامی است', true); return; }
    try {
      const r = await fetch('/support/api/templates/save', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ title, text })
      });
      if (r.ok) {
        showToast('✓ تمپلیت ذخیره شد');
        closeModal('modal-tpl');
        const row = document.getElementById('templatesRow');
        const btn = document.createElement('button');
        btn.className = 'tpl-btn';
        btn.title = text;
        btn.textContent = '⚡ ' + title;
        btn.onclick = () => useTemplate(text);
        row.insertBefore(btn, row.lastElementChild);
        document.getElementById('tpl-title').value = '';
        document.getElementById('tpl-text').value = '';
      }
    } catch(e) { showToast('❌ خطا', true); }
  }

  /* ── refresh conv list sidebar ── */
  async function refreshConvList() {
    try {
      const r = await fetch('/support/api/conversations');
      const data = await r.json();
      const convs = data.conversations || [];
      const stats = data.stats || {};
      document.getElementById('statConvs').textContent = stats.totalConvs || convs.length;
      document.getElementById('statMsgs').textContent = stats.totalMessages || '';
      document.getElementById('statToday').textContent = stats.todayMessages || '';
      document.getElementById('statUnanswered').textContent = stats.unanswered || 0;

      convs.forEach(conv => {
        const item = document.getElementById('conv-' + conv.conversationId);
        if (item) {
          const preview = item.querySelector('.conv-preview');
          if (preview && conv.lastMessage) preview.textContent = conv.lastMessage.text.substring(0,40);
          const timeEl = item.querySelector('.conv-time');
          if (timeEl && conv.lastMessage) {
            timeEl.textContent = new Date(conv.lastMessage.createdAt).toLocaleTimeString('fa-IR',{hour:'2-digit',minute:'2-digit'});
          }
        }
      });
    } catch(e) {}
  }

  /* ── search ── */
  function filterConversations(q) {
    document.querySelectorAll('.conv-item').forEach(item => {
      const name = item.querySelector('.conv-name')?.textContent?.toLowerCase() || '';
      const tagOk = !activeTagFilter || (item.dataset.tag === activeTagFilter);
      item.style.display = (name.includes(q.toLowerCase()) && tagOk) ? '' : 'none';
    });
    const visible = document.querySelectorAll('.conv-item:not([style*="none"])').length;
    document.getElementById('convCount').textContent = q ? `${visible} نتیجه` : `${document.querySelectorAll('.conv-item').length} مکالمه`;
  }

  /* ── keyboard shortcuts ── */
  document.addEventListener('keydown', e => {
    const input = document.getElementById('msgInput');
    if (!input) return;
    if (document.activeElement === input && e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  /* ── auto-resize textarea ── */
  document.getElementById('msgInput')?.addEventListener('input', function() {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 120) + 'px';
  });

  /* ── toast ── */
  function showToast(msg, isError = false) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast' + (isError ? ' error' : '');
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2500);
  }

  /* ── init ── */
  const initCount = document.querySelectorAll('.conv-item').length;
  document.getElementById('convCount').textContent = `${initCount} مکالمه`;

  // close modals on backdrop click
  document.querySelectorAll('.modal-overlay').forEach(o => o.addEventListener('click', e => {
    if (e.target === o) o.classList.remove('open');
  }));

  // poll conv list every 10s
  setInterval(refreshConvList, 10000);
</script>
</body>
</html>
