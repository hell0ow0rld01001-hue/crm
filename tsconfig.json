{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "target": "ES2023",
    "module": "commonjs",
    "baseUrl": ".",
    "paths": {
      "*": ["*"]
    },
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "*.js",
    "controller/**/*",
    "routers/**/*",
    "model/**/*",
    "services/**/*",
    "views/**/*",
    "public/**/*"
  ],
  "exclude": [
    "node_modules",
    "**/*.test.js"
  ]
}
